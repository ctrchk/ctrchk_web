{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/verify-email",
      "destination": "/api/password-reset?action=verify-email"
    },
    {
      "source": "/api/discord-profile",
      "destination": "/api/oauth?action=discord-profile"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)\\.html$",
      "destination": "/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/push?action=cron-remind",
      "schedule": "0 1 * * *"
    }
  ]
}
